{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vivid",
  "version": "0.1.0",
  "identifier": "com.vivid.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vivid Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/vivid-inference-sidecar"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://updates.vivid.studio/{{target}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_WITH_VIVID_UPDATER_PUBLIC_KEY"
    }
  }
}
