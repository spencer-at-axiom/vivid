{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "vivid-inference-sidecar",
          "sidecar": true
        },
        {
          "name": "binaries/vivid-inference-sidecar",
          "sidecar": true
        }
      ]
    }
  ]
}
